{
  "name": "contextchat-desktop",
  "version": "0.1.0",
  "description": "System-wide local AI assistant for text selections and screenshots",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
